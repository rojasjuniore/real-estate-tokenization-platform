# ============== DATABASE ==============
DATABASE_URL=postgresql://user:password@localhost:5432/buidingtok?schema=public
# REDIS_URL=redis://localhost:6379

# ============== BLOCKCHAIN ==============
NEXT_PUBLIC_CHAIN_ID=137
NEXT_PUBLIC_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Testnet (Polygon Amoy)
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
# Mainnet
POLYGON_RPC_URL=https://polygon-rpc.com

# ============== CONTRACT ADDRESSES (Mainnet) ==============
# (Set after deployment)
NEXT_PUBLIC_PROPERTY_TOKEN_ADDRESS=0x...
NEXT_PUBLIC_PROPERTY_MARKETPLACE_ADDRESS=0x...
NEXT_PUBLIC_ROYALTY_DISTRIBUTOR_ADDRESS=0x...
NEXT_PUBLIC_PAYMENT_PROCESSOR_ADDRESS=0x...

# ============== CONTRACT ADDRESSES (Polygon Amoy Testnet) ==============
# (Set after running: npx hardhat run scripts/deploy-faucet.js --network polygonAmoy)
NEXT_PUBLIC_USDC_ADDRESS_AMOY=0x...
NEXT_PUBLIC_PROPERTY_TOKEN_ADDRESS_AMOY=0x...
NEXT_PUBLIC_PROPERTY_MARKETPLACE_ADDRESS_AMOY=0x...
NEXT_PUBLIC_FAUCET_ADDRESS_AMOY=0x...

# ============== TOKEN ADDRESSES (Polygon Mainnet) ==============
NEXT_PUBLIC_USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
NEXT_PUBLIC_USDC_ADDRESS=0x3c499c542cef5e3811e1192ce70d8cc03d5c3359

# ============== WEB3AUTH ==============
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=YOUR_WEB3AUTH_CLIENT_ID
WEB3AUTH_SECRET=YOUR_WEB3AUTH_SECRET

# ============== STORAGE (IPFS) ==============
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET_KEY=YOUR_PINATA_SECRET_KEY
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ============== EXTERNAL SERVICES ==============
ALCHEMY_API_KEY=YOUR_ALCHEMY_API_KEY
ALCHEMY_WEBHOOK_SECRET=YOUR_ALCHEMY_WEBHOOK_SECRET
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ============== AUTH ==============
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# ============== ADMIN ==============
# Comma-separated list of wallet addresses with admin access
ADMIN_WALLET_ADDRESSES=0x...,0x...
NEXT_PUBLIC_ADMIN_WALLET_ADDRESSES=0x...,0x...
TREASURY_WALLET_ADDRESS=0x...
# Treasury private key for creating listings (tokens are minted to treasury)
TREASURY_PRIVATE_KEY=your-treasury-private-key-without-0x

# ============== DEPLOYER ==============
# Private key for contract deployment (without 0x prefix)
PRIVATE_KEY=YOUR_DEPLOYER_PRIVATE_KEY

# ============== OPTIONAL ==============
REPORT_GAS=false
