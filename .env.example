# ============== APP ==============
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TokenByU

# ============== WHITE LABEL / BRANDING ==============
# Uncomment and set to rebrand the platform. Defaults match TokenByU/BuildingTok.
# NEXT_PUBLIC_COMPANY_NAME=BuildingTok
# NEXT_PUBLIC_LEGAL_NAME=BUILDINGTOK S.A.S.
# NEXT_PUBLIC_TAX_ID=CUIT 30-71812345-6
# NEXT_PUBLIC_TAGLINE=Tokenización de Bienes Raíces
# NEXT_PUBLIC_DESCRIPTION=Invierte en propiedades premium desde $100.
# NEXT_PUBLIC_LOCALE=es_ES
# NEXT_PUBLIC_SUPPORT_EMAIL=soporte@tokenbyu.com
# NEXT_PUBLIC_TELEGRAM_HANDLE=@tokenbyu_soporte

# -- Colors (hex values) --
