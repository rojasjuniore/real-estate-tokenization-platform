# NEXT_PUBLIC_COLOR_ACCENT_GREEN=#16d63d
# NEXT_PUBLIC_COLOR_ACCENT_ORANGE=#FF6B35
# NEXT_PUBLIC_MANIFEST_THEME_COLOR=#0e4d80
# NEXT_PUBLIC_MANIFEST_BG_COLOR=#FFFFFF

